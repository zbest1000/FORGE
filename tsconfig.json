// Client-side typecheck. Server code is excluded for now — it has a thicket
// of JSDoc-vs-runtime mismatches around Error subclassing, Fastify request
// types, and OTEL span context that need proper @typedef annotations rather
// than a quick fix. The CI pipeline still runs `node --check` (syntax) and
// the "Boot smoke" step which imports every server module in a fresh node
// process to catch module-load-time ReferenceErrors — the bug class this
// gate originally existed to prevent.
{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "strictNullChecks": false,
    "alwaysStrict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["es2022", "dom", "dom.iterable"]
  },
  "include": [
    "app.js",
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "server",
    "scripts"
  ]
}
