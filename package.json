{
  "name": "forge",
  "version": "0.3.0",
  "description": "FORGE — Federated Operations, Research, Governance, and Engineering. Self-hostable engineering collaboration platform (client + server).",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "FORGE_SERVE_SOURCE=1 node --watch server/main.js",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "release:check": "npm run build && npm test && npm run smoke:built",
    "release:archive": "node scripts/release/pack-archive.js",
    "smoke:built": "node scripts/smoke-built.js",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/main.js",
    "seed": "node server/seed.js",
    "migrate": "node server/db.js --migrate-only",
    "backup": "node server/backup.js backup",
    "restore": "node server/backup.js restore",
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "sbom": "cyclonedx-npm --output-file bom.json",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "license:keygen": "node scripts/license/keygen.js",
    "license:issue": "node scripts/license/issue.js",
    "license:inspect": "node scripts/license/inspect.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "dompurify": "^3.4.1",
    "dxf-viewer": "^1.0.47",
    "echarts": "^6.0.0",
    "fastify": "^5.1.0",
    "fuse.js": "^7.3.0",
    "graphql": "^16.13.2",
    "marked": "^18.0.2",
    "mercurius": "^16.9.0",
    "mermaid": "^11.14.0",
    "minisearch": "^7.2.0",
    "mqtt": "^5.10.1",
    "online-3d-viewer": "^0.18.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.6.205",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "rapidoc": "^9.3.8",
    "svg-pan-zoom": "^3.6.2",
    "three": "^0.184.0",
    "uplot": "^1.6.32",
    "web-ifc": "^0.0.77",
    "xstate": "^5.30.0"
  },
  "optionalDependencies": {
    "node-opcua": "^2.132.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "vite": "^8.0.10"
  }
}
