# FORGE server configuration. Copy to `.env` (or export into your shell) and
# set real values before starting the server in production.

# Port / host.
PORT=3000
HOST=0.0.0.0

# JWT signing secret. **Required in production.** Rotate periodically.
# Generate one with:  openssl rand -hex 32
FORGE_JWT_SECRET=change-me-with-openssl-rand-hex-32

# HMAC key used to sign audit packs and approval decisions. Rotate via KMS.
# Generate one with:  openssl rand -hex 32
FORGE_TENANT_KEY=change-me-with-openssl-rand-hex-32
FORGE_TENANT_KEY_ID=key:forge:v1

# Data directory (writable; SQLite + WAL lives here).
FORGE_DATA_DIR=./data

# CORS origins, comma-separated. Leave blank for `*` (dev only).
# FORGE_CORS_ORIGIN=https://forge.example.com,https://app.example.com

# Optional MQTT bridge. Leave URL unset to disable.
# FORGE_MQTT_URL=mqtt://localhost:1883
# FORGE_MQTT_TOPICS=forge/#,plant/+/alarm/#
# FORGE_MQTT_USERNAME=
# FORGE_MQTT_PASSWORD=

# Logging.
LOG_LEVEL=info
NODE_ENV=production

# ---- n8n integration (optional) ----
# Internal URL FORGE uses to talk to n8n's REST API.
# In docker-compose, the service name resolves: http://n8n:5678
FORGE_N8N_URL=
# n8n public API key (Settings → API in n8n). Used by FORGE's admin proxy.
FORGE_N8N_API_KEY=

# n8n service (used only by docker-compose).
# Override these in production.
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ---- AI provider routing (optional) ----
# JSON: which providers are allowed and which is the default.
# FORGE_AI_POLICY={"default":"local","allow":["local","openai","ollama"]}
# FORGE_AI_OPENAI_KEY=sk-...
